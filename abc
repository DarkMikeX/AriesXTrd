## **🎯 SIGNAL GENERATION ALGORITHM**

### **How Bot Combines All Indicators:**

```javascript
function generateSignal(indicators) {
  let buyPoints = 0;
  let sellPoints = 0;
  
  // 1. Check RSI
  if (indicators.rsi < 30) buyPoints += 2;      // Strong oversold
  else if (indicators.rsi < 40) buyPoints += 1; // Mild oversold
  else if (indicators.rsi > 70) sellPoints += 2;      // Strong overbought
  else if (indicators.rsi > 60) sellPoints += 1; // Mild overbought
  
  // 2. Check MACD
  if (indicators.macd > indicators.signal && indicators.macdHistogram > 0) {
    buyPoints += 2; // Bullish crossover
  } else if (indicators.macd < indicators.signal && indicators.macdHistogram < 0) {
    sellPoints += 2; // Bearish crossover
  }
  
  // 3. Check Bollinger Bands
  if (indicators.price < indicators.bollinger.lower) buyPoints += 1;
  if (indicators.price > indicators.bollinger.upper) sellPoints += 1;
  
  // 4. Check EMA
  if (indicators.price > indicators.ema50) buyPoints += 1;
  if (indicators.price < indicators.ema50) sellPoints += 1;
  
  // 5. Check SMA
  if (indicators.price > indicators.sma200) buyPoints += 1;
  if (indicators.price < indicators.sma200) sellPoints += 1;
  
  // 6. Check Stochastic
  if (indicators.stochastic < 20) buyPoints += 1;
  if (indicators.stochastic > 80) sellPoints += 1;
  
  // 7. Check Volume
  if (indicators.volumeTrend === 'increasing' && buyPoints > sellPoints) {
    buyPoints += 1; // Volume confirms buy
  } else if (indicators.volumeTrend === 'increasing' && sellPoints > buyPoints) {
    sellPoints += 1; // Volume confirms sell
  }
  
  // Calculate confidence
  const totalPoints = buyPoints + sellPoints;
  const confidence = Math.round((Math.max(buyPoints, sellPoints) / totalPoints) * 100);
  
  // Determine signal
  if (buyPoints > sellPoints && confidence >= 75) {
    return {
      signal: 'BUY',
      type: 'CALL',
      confidence: confidence,
      strength: buyPoints >= 7 ? 'STRONG' : 'MODERATE'
    };
  } else if (sellPoints > buyPoints && confidence >= 75) {
    return {
      signal: 'SELL',
      type: 'PUT',
      confidence: confidence,
      strength: sellPoints >= 7 ? 'STRONG' : 'MODERATE'
    };
  } else {
    return {
      signal: 'WAIT',
      type: 'NONE',
      confidence: 0,
      strength: 'WEAK'
    };
  }
}
```

